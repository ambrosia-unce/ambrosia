# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Random secret for next-auth JWT signing (min 32 chars)
# Generate: openssl rand -base64 32
AUTH_SECRET=

# SQLite database file path (default: sqlite.db)
# DATABASE_URL=sqlite.db

# EthicalAds publisher ID (optional)
# Register at: https://ethicalads.io/publishers/
# Without this, a "Become a sponsor" fallback is shown instead
# NEXT_PUBLIC_ETHICAL_AD_PUBLISHER=your-publisher-id
