{
  "name": "@ambrosia-unce/events",
  "version": "1.0.0",
  "description": "High-performance event bus for Ambrosia DI framework",
  "type": "module",
  "license": "MIT",
  "author": "Ambrosia Framework",
  "homepage": "https://github.com/ambrosia-unce/ambrosia/tree/master/packages/events",
  "repository": {
    "type": "git",
    "url": "https://github.com/ambrosia-unce/ambrosia.git",
    "directory": "packages/events"
  },
  "bugs": {
    "url": "https://github.com/ambrosia-unce/ambrosia/issues"
  },
  "keywords": [
    "event-bus",
    "events",
    "event-emitter",
    "dependency-injection",
    "typescript",
    "bun",
    "decorators",
    "ambrosia"
  ],
  "engines": {
    "bun": ">=1.3.6"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "prepublishOnly": "bun run typecheck && bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ambrosia-unce/core": "workspace:*",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  }
}
