{
  "name": "@ambrosia-unce/validator",
  "version": "1.0.2",
  "description": "Type-safe compile-time validation for Ambrosia framework",
  "type": "module",
  "license": "MIT",
  "author": "Ambrosia Framework",
  "homepage": "https://github.com/ambrosia-unce/ambrosia/tree/master/packages/validator",
  "repository": {
    "type": "git",
    "url": "https://github.com/ambrosia-unce/ambrosia.git",
    "directory": "packages/validator"
  },
  "bugs": {
    "url": "https://github.com/ambrosia-unce/ambrosia/issues"
  },
  "keywords": [
    "ambrosia",
    "validation",
    "type-safe",
    "compile-time",
    "branded-types",
    "bun",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3.6"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "default": "./dist/plugin/index.js"
    },
    "./preload": "./preload.ts",
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "preload.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "prepublishOnly": "bun run build",
    "test": "echo no tests"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
