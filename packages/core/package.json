{
  "name": "@ambrosia-unce/core",
  "version": "0.1.0",
  "description": "Lightweight decorator-based Dependency Injection container for TypeScript and Bun",
  "type": "module",
  "license": "MIT",
  "author": "Ambrosia Framework",
  "homepage": "https://github.com/ambrosia-unce/ambrosia/tree/master/packages/core",
  "repository": {
    "type": "git",
    "url": "https://github.com/ambrosia-unce/ambrosia.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/ambrosia-unce/ambrosia/issues"
  },
  "keywords": [
    "dependency-injection",
    "di",
    "ioc",
    "inversion-of-control",
    "typescript",
    "bun",
    "decorators",
    "ambrosia"
  ],
  "engines": {
    "bun": ">=1.3.6"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "prepublishOnly": "bun run typecheck && bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "typecheck": "tsc --noEmit",
    "bench": "bun run benchmarks/run-all.ts",
    "bench:core": "bun test ./benchmarks/suites/01-core-di.bench.ts",
    "bench:scopes": "bun test ./benchmarks/suites/02-scopes.bench.ts",
    "bench:plugins": "bun test ./benchmarks/suites/03-plugins.bench.ts",
    "bench:async": "bun test ./benchmarks/suites/04-async.bench.ts",
    "bench:memory": "bun test ./benchmarks/suites/05-memory.bench.ts",
    "bench:real-world": "bun test ./benchmarks/suites/06-real-world.bench.ts",
    "bench:compare": "bun run benchmarks/compare.ts",
    "bench:watch": "bun test --watch ./benchmarks/suites/*.bench.ts",
    "example:errors": "bun run examples/error-handling-example.ts",
    "example:circular": "bun run examples/circular-dependency-solutions.ts",
    "example:auto": "bun run examples/auto-registration-example.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  }
}
