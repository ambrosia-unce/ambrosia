{
  "name": "@ambrosia-unce/config",
  "version": "1.0.0",
  "description": "Type-safe environment configuration for Ambrosia framework with schema validation and zero runtime overhead",
  "type": "module",
  "license": "MIT",
  "author": "Ambrosia Framework",
  "homepage": "https://github.com/ambrosia-unce/ambrosia/tree/master/packages/config",
  "repository": {
    "type": "git",
    "url": "https://github.com/ambrosia-unce/ambrosia.git",
    "directory": "packages/config"
  },
  "bugs": {
    "url": "https://github.com/ambrosia-unce/ambrosia/issues"
  },
  "keywords": [
    "config",
    "configuration",
    "env",
    "environment",
    "typescript",
    "bun",
    "ambrosia",
    "dependency-injection"
  ],
  "engines": {
    "bun": ">=1.3.6"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "prepublishOnly": "bun run typecheck && bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "@ambrosia-unce/core": "workspace:*",
    "typescript": "^5"
  },
  "publishConfig": {
    "access": "public"
  }
}
