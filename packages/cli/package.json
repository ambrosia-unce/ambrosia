{
  "name": "@ambrosia/cli",
  "version": "0.1.0",
  "description": "CLI tool for scaffolding Ambrosia framework projects",
  "type": "module",
  "license": "MIT",
  "author": "Ambrosia Framework",
  "homepage": "https://github.com/unmake/ambrosia/tree/master/packages/cli",
  "repository": {
    "type": "git",
