    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/unmake/ambrosia/issues"
  },
  "keywords": [
    "ambrosia",
    "cli",
    "scaffolding",
    "generator",
    "bun",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3.6"
  },
  "bin": {
    "ambrosia": "./dist/bin.js",
    "amb": "./dist/bin.js"
  },
  "main": "./dist/bin.js",
  "files": [
