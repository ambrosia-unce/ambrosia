{
  "name": "@ambrosia-unce/http-elysia",
  "version": "1.0.0",
  "description": "Elysia.js HTTP provider for Ambrosia framework",
  "type": "module",
  "license": "MIT",
  "author": "Ambrosia Framework",
  "homepage": "https://github.com/ambrosia-unce/ambrosia/tree/master/packages/http-elysia",
  "repository": {
    "type": "git",
    "url": "https://github.com/ambrosia-unce/ambrosia.git",
    "directory": "packages/http-elysia"
  },
  "bugs": {
    "url": "https://github.com/ambrosia-unce/ambrosia/issues"
  },
  "keywords": [
    "ambrosia",
    "elysia",
    "http",
    "adapter",
    "bun",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3.6"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build.ts",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ambrosia-unce/http": "workspace:*"
  },
  "peerDependencies": {
    "elysia": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "elysia": "^1.4.22"
  }
}
