{
  "name": "@ambrosia-unce/websocket-elysia",
  "version": "1.0.0",
  "description": "Elysia.js WebSocket adapter for @ambrosia-unce/websocket",
  "type": "module",
  "license": "MIT",
  "author": "Ambrosia Framework",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ambrosia-unce/websocket": "workspace:*",
    "elysia": "^1.4.22"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
