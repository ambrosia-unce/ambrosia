{
  "name": "@ambrosia/devtools",
  "version": "0.1.0",
  "description": "DevTools dashboard backend for the Ambrosia framework — introspection, live events, and plugin system",
  "type": "module",
  "license": "MIT",
  "author": "Ambrosia Framework",
  "homepage": "https://github.com/ambrosia-unce/ambrosia/tree/master/packages/devtools",
  "repository": {
    "type": "git",
    "url": "https://github.com/ambrosia-unce/ambrosia.git",
    "directory": "packages/devtools"
  },
  "bugs": {
    "url": "https://github.com/ambrosia-unce/ambrosia/issues"
  },
  "keywords": [
    "devtools",
    "dashboard",
    "debugging",
    "introspection",
    "typescript",
    "bun",
    "ambrosia"
  ],
  "engines": {
    "bun": ">=1.3.6"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun run build.ts",
    "prepublishOnly": "bun run typecheck && bun run build",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5",
    "@ambrosia/events": "workspace:*",
    "@ambrosia/config": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@ambrosia/events": {
      "optional": true
    },
    "@ambrosia/config": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@ambrosia/core": "workspace:*",
    "@ambrosia/http": "workspace:*",
    "reflect-metadata": "^0.2.2"
  }
}
