{
  "name": "ambrosia",
  "version": "0.0.1",
  "description": "-",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter \"./packages/*\" build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "typecheck": "bun run --filter \"./packages/*\" typecheck",
    "test": "bun run --filter \"./packages/*\" test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.2",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "^1.3.9",
    "bun-types": "^1.3.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "author": "svallotale",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.9"
  },
  "dependencies": {
    "elysia": "^1.4.25"
  }
}